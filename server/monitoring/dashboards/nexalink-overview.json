{
  "title": "NexaLink Overview",
  "uid": "nexalink-overview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Active Users (last 5m)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "synapse_util_metrics_gauge{name=\"active_users\"}",
        "legendFormat": "Active users"
      }],
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [
        {"color": "green", "value": null}, {"color": "yellow", "value": 100}, {"color": "red", "value": 1000}
      ]}}}
    },
    {
      "id": 2, "type": "stat", "title": "Messages / min",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "rate(synapse_http_server_requests_received_total{servlet=\"RoomSendEventRestServlet\"}[1m]) * 60",
        "legendFormat": "Messages/min"
      }],
      "options": { "colorMode": "background", "graphMode": "area" }
    },
    {
      "id": 3, "type": "stat", "title": "Server RAM",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "100 - ((node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100)",
        "legendFormat": "RAM %"
      }],
      "options": { "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "percent", "color": { "mode": "thresholds" }, "thresholds": { "steps": [
        {"color": "green", "value": null}, {"color": "yellow", "value": 70}, {"color": "red", "value": 90}
      ]}}}
    },
    {
      "id": 4, "type": "stat", "title": "CPU Load",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "100 - (avg by(instance)(irate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
        "legendFormat": "CPU %"
      }],
      "options": { "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "percent", "color": { "mode": "thresholds" }, "thresholds": { "steps": [
        {"color": "green", "value": null}, {"color": "yellow", "value": 60}, {"color": "red", "value": 85}
      ]}}}
    },
    {
      "id": 5, "type": "timeseries", "title": "HTTP Requests (Synapse)",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(synapse_http_server_requests_received_total[1m])",
          "legendFormat": "{{servlet}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 6, "type": "timeseries", "title": "Disk Usage",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "100 - ((node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"}) * 100)",
          "legendFormat": "Disk %"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" } }
    },
    {
      "id": 7, "type": "timeseries", "title": "Database Connections (PgBouncer pools)",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "pg_stat_activity_count",
          "legendFormat": "Active DB connections"
        }
      ]
    },
    {
      "id": 8, "type": "timeseries", "title": "Network I/O",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{device!=\"lo\"}[1m])",
          "legendFormat": "RX {{device}}"
        },
        {
          "expr": "rate(node_network_transmit_bytes_total{device!=\"lo\"}[1m])",
          "legendFormat": "TX {{device}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" } }
    }
  ]
}
