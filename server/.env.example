# =============================================================================
# NexaLink Server Configuration — WhatsApp-style relay model
# Copy this file to .env and edit the values below.
# Or run: sudo bash scripts/setup.sh  (generates .env automatically)
# =============================================================================

# --- Network ---
# Public IP or domain of this server (no http:// prefix)
SERVER_HOST=72.56.244.207

# Ports exposed on the host
HTTP_PORT=80
HTTPS_PORT=443
SYNAPSE_PORT=8008
TURN_PORT=3478
TURN_TLS_PORT=5349
TURN_RELAY_MIN=49152
TURN_RELAY_MAX=49172

# --- Core Server ---
# Server name used in user IDs (@user:SERVER_NAME)
SYNAPSE_SERVER_NAME=72.56.244.207
SYNAPSE_REPORT_STATS=no

# Registration: set to "true" to allow open registration
ENABLE_REGISTRATION=true

# Shared secret for admin operations (auto-generated by setup.sh)
REGISTRATION_SHARED_SECRET=CHANGE_ME

# --- PostgreSQL ---
POSTGRES_DB=synapse
POSTGRES_USER=synapse
POSTGRES_PASSWORD=CHANGE_ME

# --- Coturn (TURN/STUN for voice/video calls) ---
TURN_SECRET=CHANGE_ME

# --- Admin API token for relay cleanup script ---
# Used by cleanup.sh to purge delivered messages via Synapse Admin API.
# Auto-generated by setup.sh — do not share.
SYNAPSE_ADMIN_TOKEN=CHANGE_ME

# --- Branding ---
ELEMENT_BRAND=NexaLink

# --- Admin ---
# First admin user credentials (created by setup.sh)
ADMIN_USER=admin
ADMIN_PASSWORD=CHANGE_ME

# --- Grafana ---
GRAFANA_PASSWORD=nexalink123
