{
  "name": "nexalink",
  "version": "1.0.0",
  "description": "NexaLink — Encrypted Messenger & Social Network",
  "main": "main.js",
  "author": "NexaLink",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64",
    "build:linux": "electron-builder --linux --x64",
    "build:all": "electron-builder --win --linux --x64"
  },
  "build": {
    "appId": "io.nexalink.app",
    "productName": "NexaLink",
    "directories": {
      "output": "../server/nginx/www/nexalink/installers/desktop"
    },
    "files": [
      "main.js",
      "preload.js",
      "icon.png"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "icon.png",
      "artifactName": "NexaLink-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "NexaLink"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        }
      ],
      "icon": "icon.png",
      "category": "Network",
      "artifactName": "NexaLink-${version}.${ext}"
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
