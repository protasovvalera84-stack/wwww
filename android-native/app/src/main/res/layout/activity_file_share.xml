<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#0A0A12">
    <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingHorizontal="12dp" android:background="#111118">
        <ImageButton android:id="@+id/btnBack" android:layout_width="40dp" android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_revert" android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#888" android:contentDescription="Back" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:text="Send File" android:textSize="18sp" android:textColor="#E0E0E0"
            android:textStyle="bold" android:paddingStart="8dp" />
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
        android:orientation="vertical" android:gravity="center" android:padding="32dp">
        <Button android:id="@+id/btnPickFile" android:layout_width="match_parent" android:layout_height="56dp"
            android:text="Choose File" android:textColor="#A855F7" android:background="@drawable/btn_secondary"
            android:textSize="16sp" android:textAllCaps="false" android:layout_marginBottom="24dp" />
        <TextView android:id="@+id/tvFileName" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="No file selected" android:textColor="#E0E0E0" android:textSize="16sp"
            android:gravity="center" android:layout_marginBottom="8dp" />
        <TextView android:id="@+id/tvFileSize" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="#666" android:textSize="13sp" android:gravity="center" android:layout_marginBottom="32dp" />
        <Button android:id="@+id/btnSend" android:layout_width="match_parent" android:layout_height="52dp"
            android:text="Send" android:textColor="#FFF" android:background="@drawable/btn_primary"
            android:textSize="16sp" android:textAllCaps="false" />
        <ProgressBar android:id="@+id/progress" android:layout_width="32dp" android:layout_height="32dp"
            android:indeterminateTint="#A855F7" android:visibility="gone" android:layout_marginTop="16dp" />
    </LinearLayout>
</LinearLayout>
