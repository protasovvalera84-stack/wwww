<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#0A0A12">

    <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingHorizontal="12dp" android:background="#111118">
        <ImageButton android:id="@+id/btnBack" android:layout_width="40dp" android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_revert" android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#888" android:contentDescription="Back" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:text="Settings" android:textSize="18sp" android:textColor="#E0E0E0"
            android:textStyle="bold" android:paddingStart="8dp" />
    </LinearLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">

            <!-- Notifications -->
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Notifications" android:textColor="#A855F7" android:textSize="13sp"
                android:textStyle="bold" android:layout_marginBottom="8dp" />
            <LinearLayout android:layout_width="match_parent" android:layout_height="48dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingHorizontal="12dp" android:background="@drawable/input_bg" android:layout_marginBottom="16dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="Push notifications" android:textColor="#E0E0E0" android:textSize="14sp" />
                <Switch android:id="@+id/switchNotifications" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:thumbTint="#A855F7" android:trackTint="#333" />
            </LinearLayout>

            <!-- Appearance -->
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Appearance" android:textColor="#A855F7" android:textSize="13sp"
                android:textStyle="bold" android:layout_marginBottom="8dp" />
            <LinearLayout android:layout_width="match_parent" android:layout_height="48dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingHorizontal="12dp" android:background="@drawable/input_bg" android:layout_marginBottom="16dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="Dark mode" android:textColor="#E0E0E0" android:textSize="14sp" />
                <Switch android:id="@+id/switchDarkMode" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:thumbTint="#A855F7" android:trackTint="#333" />
            </LinearLayout>

            <!-- Storage -->
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Storage" android:textColor="#A855F7" android:textSize="13sp"
                android:textStyle="bold" android:layout_marginBottom="8dp" />
            <TextView android:id="@+id/tvStorageInfo" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Loading..." android:textColor="#888" android:textSize="13sp"
                android:padding="12dp" android:background="@drawable/input_bg" android:layout_marginBottom="8dp" />
            <Button android:id="@+id/btnClearAllData" android:layout_width="match_parent" android:layout_height="44dp"
                android:text="Clear All Data" android:textColor="#EF4444" android:background="@drawable/btn_secondary"
                android:textSize="13sp" android:textAllCaps="false" android:layout_marginBottom="16dp" />

            <!-- About -->
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="About" android:textColor="#A855F7" android:textSize="13sp"
                android:textStyle="bold" android:layout_marginBottom="8dp" />
            <TextView android:id="@+id/tvVersion" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="NexaLink v1.0.0" android:textColor="#E0E0E0" android:textSize="14sp"
                android:padding="12dp" android:background="@drawable/input_bg" android:layout_marginBottom="4dp" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Server" android:textColor="#888" android:textSize="11sp"
                android:paddingHorizontal="12dp" android:layout_marginTop="8dp" />
            <TextView android:id="@+id/tvServer" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textColor="#666" android:textSize="12sp" android:paddingHorizontal="12dp" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
