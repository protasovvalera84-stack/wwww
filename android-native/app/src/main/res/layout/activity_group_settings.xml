<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#0A0A12">
    <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingHorizontal="12dp" android:background="#111118">
        <ImageButton android:id="@+id/btnBack" android:layout_width="40dp" android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_revert" android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#888" android:contentDescription="Back" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:text="Group Settings" android:textSize="18sp" android:textColor="#E0E0E0"
            android:textStyle="bold" android:paddingStart="8dp" />
    </LinearLayout>
    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">
            <TextView android:id="@+id/tvGroupName" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textSize="22sp" android:textColor="#E0E0E0" android:textStyle="bold" android:gravity="center"
                android:layout_marginBottom="16dp" />
            <EditText android:id="@+id/etGroupName" android:layout_width="match_parent" android:layout_height="48dp"
                android:textColor="#E0E0E0" android:textColorHint="#555" android:background="@drawable/input_bg"
                android:paddingHorizontal="16dp" android:textSize="14sp" android:hint="Group name" />
            <Button android:id="@+id/btnSaveName" android:layout_width="match_parent" android:layout_height="44dp"
                android:text="Save Name" android:textColor="#FFF" android:background="@drawable/btn_primary"
                android:textSize="13sp" android:textAllCaps="false" android:layout_marginTop="8dp" />
            <TextView android:id="@+id/tvMemberCount" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Members" android:textColor="#A855F7" android:textSize="14sp"
                android:textStyle="bold" android:layout_marginTop="24dp" android:layout_marginBottom="8dp" />
            <Button android:id="@+id/btnInvite" android:layout_width="match_parent" android:layout_height="44dp"
                android:text="Invite User" android:textColor="#A855F7" android:background="@drawable/btn_secondary"
                android:textSize="13sp" android:textAllCaps="false" android:layout_marginBottom="8dp" />
            <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvMembers"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />
            <Button android:id="@+id/btnLeave" android:layout_width="match_parent" android:layout_height="44dp"
                android:text="Leave Group" android:textColor="#EF4444" android:background="@drawable/btn_secondary"
                android:textSize="13sp" android:textAllCaps="false" android:layout_marginTop="24dp" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
