<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A12">

    <!-- Remote video (full screen) -->
    <org.webrtc.SurfaceViewRenderer
        android:id="@+id/remoteRenderer"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Local video (small overlay) -->
    <org.webrtc.SurfaceViewRenderer
        android:id="@+id/localRenderer"
        android:layout_width="120dp"
        android:layout_height="160dp"
        android:layout_gravity="top|end"
        android:layout_margin="16dp" />

    <!-- Call info overlay -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="32dp">

        <TextView
            android:id="@+id/tvCallerName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Caller"
            android:textSize="24sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCallStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Connecting..."
            android:textSize="14sp"
            android:textColor="#888"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- Bottom controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="32dp">

        <ImageButton
            android:id="@+id/btnMute"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@android:drawable/ic_btn_speak_now"
            android:background="@drawable/btn_call_action"
            android:tint="#FFFFFF"
            android:contentDescription="Mute"
            android:layout_marginEnd="24dp" />

        <ImageButton
            android:id="@+id/btnEndCall"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@android:drawable/ic_menu_call"
            android:background="@drawable/btn_end_call"
            android:tint="#FFFFFF"
            android:contentDescription="End call" />

        <ImageButton
            android:id="@+id/btnCamera"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@android:drawable/ic_menu_camera"
            android:background="@drawable/btn_call_action"
            android:tint="#FFFFFF"
            android:contentDescription="Camera"
            android:layout_marginStart="24dp" />
    </LinearLayout>
</FrameLayout>
