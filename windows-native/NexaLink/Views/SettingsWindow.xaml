<Window x:Class="NexaLink.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Width="420" Height="500"
        WindowStartupLocation="CenterOwner" Background="{StaticResource BgBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <Button Content="← Back" Background="Transparent" Foreground="{StaticResource MutedBrush}"
                    BorderThickness="0" FontSize="14" Cursor="Hand" Click="BtnBack_Click"/>
            <TextBlock Text="Settings" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}"
                       VerticalAlignment="Center" Margin="12,0"/>
        </StackPanel>
        <ScrollViewer Grid.Row="1">
            <StackPanel>
                <TextBlock Text="Notifications" Foreground="{StaticResource PrimaryBrush}" FontSize="13"
                           FontWeight="Bold" Margin="0,16,0,8"/>
                <CheckBox x:Name="cbNotifications" Content="Enable notifications" Foreground="{StaticResource TextBrush}"
                          FontSize="14" Margin="0,0,0,16" Checked="CbNotifications_Changed" Unchecked="CbNotifications_Changed"/>

                <TextBlock Text="Appearance" Foreground="{StaticResource PrimaryBrush}" FontSize="13"
                           FontWeight="Bold" Margin="0,0,0,8"/>
                <CheckBox Content="Dark mode (always on)" Foreground="{StaticResource TextBrush}"
                          FontSize="14" IsChecked="True" IsEnabled="False" Margin="0,0,0,16"/>

                <TextBlock Text="Server" Foreground="{StaticResource PrimaryBrush}" FontSize="13"
                           FontWeight="Bold" Margin="0,0,0,8"/>
                <TextBlock x:Name="tbServerUrl" Foreground="{StaticResource TextBrush}" FontSize="13" Margin="0,0,0,4"/>
                <TextBlock x:Name="tbDeviceId" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,0,0,16"/>

                <TextBlock Text="About" Foreground="{StaticResource PrimaryBrush}" FontSize="13"
                           FontWeight="Bold" Margin="0,0,0,8"/>
                <TextBlock x:Name="tbVersion" Foreground="{StaticResource TextBrush}" FontSize="13" Margin="0,0,0,4"/>
                <TextBlock Text="NexaLink — Encrypted Messenger" Foreground="{StaticResource MutedBrush}" FontSize="11"/>

                <Button Content="Clear All Data" Background="Transparent" Foreground="{StaticResource ErrorBrush}"
                        BorderThickness="0" FontSize="14" Cursor="Hand" Click="BtnClearData_Click"
                        HorizontalAlignment="Left" Margin="0,32,0,0"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
