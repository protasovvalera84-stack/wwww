<Window x:Class="NexaLink.Views.ContentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Content" Width="700" Height="550"
        WindowStartupLocation="CenterOwner" Background="{StaticResource BgBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Background="{StaticResource SurfaceBrush}" Margin="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="16,0">
                <Button Content="← Back" Background="Transparent" Foreground="{StaticResource MutedBrush}"
                        BorderThickness="0" FontSize="14" Cursor="Hand" Click="BtnBack_Click"/>
                <TextBlock x:Name="tbTitle" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"
                           VerticalAlignment="Center" Margin="12,0"/>
            </StackPanel>
        </Grid>
        <Grid Grid.Row="1">
            <ListBox x:Name="lbItems" Style="{StaticResource DarkListBox}" Margin="8">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="4,6" Cursor="Hand">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="48"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="44" Height="44" CornerRadius="8" Background="#1A1A2E">
                                <TextBlock Text="{Binding TypeIcon}" FontSize="20"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="12,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Title}" Foreground="{StaticResource TextBrush}"
                                           FontSize="14" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding Subtitle}" Foreground="{StaticResource MutedBrush}"
                                           FontSize="12" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="{Binding PriceDisplay}" Foreground="{StaticResource PrimaryBrush}"
                                       FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <TextBlock x:Name="tbEmpty" Text="No content yet" Foreground="{StaticResource MutedBrush}"
                       FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
            <ProgressBar x:Name="progress" IsIndeterminate="True" Height="3"
                         Foreground="{StaticResource PrimaryBrush}" Background="Transparent"
                         VerticalAlignment="Top" Visibility="Collapsed"/>
        </Grid>
    </Grid>
</Window>
