<Window x:Class="NexaLink.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NexaLink" Width="420" Height="550"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="{StaticResource BgBrush}">
    <Grid Margin="40">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="NexaLink" FontSize="32" FontWeight="Bold"
                       Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
            <TextBlock Text="Encrypted Messenger" FontSize="14"
                       Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Center" Margin="0,0,0,32"/>

            <TextBox x:Name="tbServer" Style="{StaticResource DarkTextBox}" Margin="0,0,0,12"
                     Tag="Server URL" Text="https://72-56-244-207.nip.io"/>
            <TextBox x:Name="tbUsername" Style="{StaticResource DarkTextBox}" Margin="0,0,0,12" Tag="Username"/>
            <PasswordBox x:Name="pbPassword" Background="#1A1A2E" Foreground="{StaticResource TextBrush}"
                         BorderBrush="#333" BorderThickness="1" Padding="12,8" FontSize="14" Margin="0,0,0,20"/>

            <Button x:Name="btnLogin" Content="Login" Style="{StaticResource PrimaryButton}"
                    Click="BtnLogin_Click" Margin="0,0,0,8"/>
            <Button x:Name="btnRegister" Content="Create Account" Background="#1A1A2E"
                    Foreground="{StaticResource PrimaryBrush}" FontSize="14" Padding="20,10"
                    BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="1" Cursor="Hand"
                    Click="BtnRegister_Click" Margin="0,0,0,16">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="#1A1A2E" CornerRadius="12" BorderBrush="{StaticResource PrimaryBrush}"
                                BorderThickness="1" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <TextBlock x:Name="tbError" Foreground="{StaticResource ErrorBrush}" FontSize="12"
                       HorizontalAlignment="Center" TextWrapping="Wrap" Visibility="Collapsed"/>
            <ProgressBar x:Name="progress" IsIndeterminate="True" Height="3"
                         Foreground="{StaticResource PrimaryBrush}" Background="Transparent"
                         Margin="0,16,0,0" Visibility="Collapsed"/>
        </StackPanel>
    </Grid>
</Window>
