<Window x:Class="NexaLink.Views.CreateChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New Chat" Width="420" Height="500"
        WindowStartupLocation="CenterOwner" Background="{StaticResource BgBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="48"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <Button Content="← Back" Background="Transparent" Foreground="{StaticResource MutedBrush}"
                    BorderThickness="0" FontSize="14" Cursor="Hand" Click="BtnBack_Click"/>
            <TextBlock Text="New Chat" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}"
                       VerticalAlignment="Center" Margin="12,0"/>
        </StackPanel>
        <TextBox x:Name="tbSearch" Grid.Row="1" Style="{StaticResource DarkTextBox}"
                 Tag="Search users..." TextChanged="TbSearch_TextChanged"/>
        <Button Grid.Row="2" Content="Create Group" Background="#1A1A2E" Foreground="{StaticResource PrimaryBrush}"
                BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="1" Padding="16,8"
                FontSize="13" Cursor="Hand" Click="BtnCreateGroup_Click" Margin="0,8,0,8" HorizontalAlignment="Stretch">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="#1A1A2E" CornerRadius="8" BorderBrush="{StaticResource PrimaryBrush}"
                            BorderThickness="1" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>
        <ListBox x:Name="lbResults" Grid.Row="3" Style="{StaticResource DarkListBox}"
                 SelectionChanged="LbResults_SelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="4,6" Cursor="Hand">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="36" Height="36" CornerRadius="18" Background="#2D1B69">
                            <TextBlock Text="👤" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="10,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding DisplayName}" Foreground="{StaticResource TextBrush}" FontSize="14"/>
                            <TextBlock Text="{Binding UserId}" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>
