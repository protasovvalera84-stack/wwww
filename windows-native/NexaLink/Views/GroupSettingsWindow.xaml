<Window x:Class="NexaLink.Views.GroupSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Group Settings" Width="420" Height="550"
        WindowStartupLocation="CenterOwner" Background="{StaticResource BgBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <Button Content="← Back" Background="Transparent" Foreground="{StaticResource MutedBrush}"
                    BorderThickness="0" FontSize="14" Cursor="Hand" Click="BtnBack_Click"/>
            <TextBlock Text="Group Settings" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}"
                       VerticalAlignment="Center" Margin="12,0"/>
        </StackPanel>
        <ScrollViewer Grid.Row="1">
            <StackPanel>
                <TextBlock x:Name="tbGroupName" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextBrush}"
                           HorizontalAlignment="Center" Margin="0,16,0,16"/>
                <TextBox x:Name="tbEditName" Style="{StaticResource DarkTextBox}" Margin="0,0,0,8"/>
                <Button Content="Save Name" Style="{StaticResource PrimaryButton}" Click="BtnSaveName_Click" Margin="0,0,0,24"/>

                <TextBlock x:Name="tbMemberCount" Foreground="{StaticResource PrimaryBrush}" FontSize="14"
                           FontWeight="Bold" Margin="0,0,0,8"/>
                <Button Content="Invite User" Background="#1A1A2E" Foreground="{StaticResource PrimaryBrush}"
                        BorderThickness="0" FontSize="13" Cursor="Hand" Padding="12,8"
                        Click="BtnInvite_Click" Margin="0,0,0,8"/>

                <ListBox x:Name="lbMembers" Style="{StaticResource DarkListBox}" MaxHeight="200">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="4,4" Cursor="Hand">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="28" Height="28" CornerRadius="14" Background="#2D1B69">
                                    <TextBlock Text="{Binding Initials}" Foreground="White" FontSize="10"
                                               FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="8,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextBrush}" FontSize="13"/>
                                    <TextBlock Text="{Binding UserId}" Foreground="{StaticResource MutedBrush}" FontSize="10"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Button Content="Leave Group" Background="Transparent" Foreground="{StaticResource ErrorBrush}"
                        BorderThickness="0" FontSize="14" Cursor="Hand" Click="BtnLeave_Click" Margin="0,24,0,0"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
