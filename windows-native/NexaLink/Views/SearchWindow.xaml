<Window x:Class="NexaLink.Views.SearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Search" Width="500" Height="500"
        WindowStartupLocation="CenterOwner" Background="{StaticResource BgBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <Button Content="← Back" Background="Transparent" Foreground="{StaticResource MutedBrush}"
                    BorderThickness="0" FontSize="14" Cursor="Hand" Click="BtnBack_Click"/>
            <TextBox x:Name="tbSearch" Style="{StaticResource DarkTextBox}" Width="350" Margin="12,0"
                     Tag="Search rooms, messages, users..." TextChanged="TbSearch_TextChanged"/>
        </StackPanel>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,4">
            <Button x:Name="btnAll" Content="All" FontSize="12" Padding="12,4" Margin="0,0,4,0"
                    Background="{StaticResource PrimaryBrush}" Foreground="White" BorderThickness="0" Cursor="Hand"
                    Click="BtnFilter_Click" Tag="all"/>
            <Button x:Name="btnRooms" Content="Rooms" FontSize="12" Padding="12,4" Margin="0,0,4,0"
                    Background="Transparent" Foreground="{StaticResource MutedBrush}" BorderThickness="0" Cursor="Hand"
                    Click="BtnFilter_Click" Tag="rooms"/>
            <Button x:Name="btnMessages" Content="Messages" FontSize="12" Padding="12,4" Margin="0,0,4,0"
                    Background="Transparent" Foreground="{StaticResource MutedBrush}" BorderThickness="0" Cursor="Hand"
                    Click="BtnFilter_Click" Tag="messages"/>
            <Button x:Name="btnUsers" Content="Users" FontSize="12" Padding="12,4"
                    Background="Transparent" Foreground="{StaticResource MutedBrush}" BorderThickness="0" Cursor="Hand"
                    Click="BtnFilter_Click" Tag="users"/>
        </StackPanel>
        <ListBox x:Name="lbResults" Grid.Row="2" Style="{StaticResource DarkListBox}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="4,4" Cursor="Hand">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Icon}" FontSize="18" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Margin="8,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Title}" Foreground="{StaticResource TextBrush}" FontSize="13"/>
                            <TextBlock Text="{Binding Subtitle}" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>
