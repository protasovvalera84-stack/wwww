<Window x:Class="NexaLink.Views.ProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Profile" Width="420" Height="550"
        WindowStartupLocation="CenterOwner" Background="{StaticResource BgBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <Button Content="← Back" Background="Transparent" Foreground="{StaticResource MutedBrush}"
                    BorderThickness="0" FontSize="14" Cursor="Hand" Click="BtnBack_Click"/>
            <TextBlock Text="Profile" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}"
                       VerticalAlignment="Center" Margin="12,0"/>
        </StackPanel>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Width="80" Height="80" CornerRadius="40" Background="#2D1B69" HorizontalAlignment="Center" Margin="0,16">
                    <TextBlock x:Name="tbAvatar" FontSize="28" FontWeight="Bold" Foreground="White"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock x:Name="tbName" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock x:Name="tbUserId" FontSize="12" Foreground="{StaticResource MutedBrush}"
                           HorizontalAlignment="Center" Margin="0,4,0,24"/>
                <TextBlock Text="Display Name" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,4"/>
                <TextBox x:Name="tbDisplayName" Style="{StaticResource DarkTextBox}" Margin="0,0,0,12"/>
                <Button Content="Save" Style="{StaticResource PrimaryButton}" Click="BtnSave_Click" Margin="0,0,0,24"/>
                <TextBlock Text="Storage" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,4"/>
                <TextBlock x:Name="tbStorage" Foreground="{StaticResource TextBrush}" FontSize="13" Margin="0,0,0,8"/>
                <Button Content="Clear Cache" Background="#1A1A2E" Foreground="{StaticResource ErrorBrush}"
                        BorderBrush="{StaticResource ErrorBrush}" BorderThickness="1" Padding="16,8"
                        FontSize="13" Cursor="Hand" Click="BtnClearCache_Click" Margin="0,0,0,24">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="#1A1A2E" CornerRadius="8" BorderBrush="{StaticResource ErrorBrush}"
                                    BorderThickness="1" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Content="Log Out" Background="Transparent" Foreground="{StaticResource ErrorBrush}"
                        BorderThickness="0" FontSize="14" Cursor="Hand" Click="BtnLogout_Click"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
