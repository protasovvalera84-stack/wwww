<Window x:Class="NexaLink.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="NexaLink" Width="1200" Height="750"
        WindowStartupLocation="CenterScreen"
        Background="#0A0A12">
    <Grid>
        <wv2:WebView2 x:Name="webView" />
        <!-- Loading screen shown while WebView initializes -->
        <StackPanel x:Name="loadingPanel"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="#0A0A12">
            <TextBlock Text="NexaLink" FontSize="36" FontWeight="Bold"
                       Foreground="#A855F7" HorizontalAlignment="Center"/>
            <TextBlock Text="Loading..." FontSize="14"
                       Foreground="#666" HorizontalAlignment="Center" Margin="0,12,0,0"/>
            <ProgressBar IsIndeterminate="True" Width="200" Height="3"
                         Foreground="#A855F7" Background="Transparent" Margin="0,12,0,0"/>
        </StackPanel>
    </Grid>
</Window>
